# Copy this file to .env in this same folder and fill in values.
# Never commit .env to git.

# --- OpenAI ---
OPENAI_API_KEY=
# Optional: override default model (default: gpt-4.1)
# OPENAI_MODEL=gpt-4.1

# --- Jira Cloud ---
# Your Atlassian Cloud base URL (no trailing slash)
JIRA_HOST=https://your-domain.atlassian.net
# Atlassian account email (must match the account that created the API token)
JIRA_EMAIL=
# API token from https://id.atlassian.com/manage-profile/security/api-tokens
JIRA_API_TOKEN=

# --- Bitbucket Data Center / Server (e.g. stash.company.com) ---
# Base URL of your Bitbucket Server instance
BITBUCKET_SERVER_URL=https://stash.example.com
# Your Bitbucket username (as shown on your profile)
BITBUCKET_USERNAME=
# App password or HTTP access token (used as Basic auth password)
BITBUCKET_APP_PASSWORD=
# Alternative: Bearer token (only if your org supports it and Basic is not available)
# BITBUCKET_ACCESS_TOKEN=

# --- Optional tuning ---
# Max characters of PR diff sent to LLM (default: 120000)
# JIRA_QA_MAX_DIFF_CHARS=120000
