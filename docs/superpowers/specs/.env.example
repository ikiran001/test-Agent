# Copy to ".env" in this folder and fill in values. Never commit ".env".
#
# Required for this script
OPENAI_API_KEY=
# gpt-4.1 is strong but uses more TPM; for experiments try gpt-4o-mini to reduce 429 rate limits
# OPENAI_MODEL=gpt-4.1

# --- Exactly one demo mode recommended: set ONE of these to 1 ---
# 0/0 = safe smoke test (opens example.com unless you customize default task in code paths)

# Hosted / dashboard UI verification (login + navigate to Hosting URL, summarize visible UI)
USE_UI_VERIFY=0
# Full HTTPS URLs (either use APP_* below OR equivalent BLUEHOST_* aliases)
APP_LOGIN_URL=
APP_HOSTING_VERIFY_URL=
# Optional aliases (same semantics as APP_* if you prefer Bluehost-specific names)
BLUEHOST_LOGIN_URL=
BLUEHOST_HOSTING_URL=
# Credentials for USE_UI_VERIFY (first match wins per column)
HOSTING_EMAIL=
HOSTING_PASSWORD=
APP_EMAIL=
APP_PASSWORD= (separate credentials; task sends values to LLM — test accounts only)
USE_LINKEDIN_DEMO=0
LINKEDIN_EMAIL=
LINKEDIN_PASSWORD=

# Playwright MCP: headed (visible browser) by default. Set =1 **only** to force headless.
# PLAYWRIGHT_MCP_HEADLESS=0

# 1 = do not pass --isolated to playwright-mcp (only if you know you need the default profile)
# PLAYWRIGHT_MCP_NO_ISOLATED=0

# Max agent steps (default 50). LangGraph recursion_limit = 2x this. Raise for long sites.
# AGENT_MAX_STEPS=50
