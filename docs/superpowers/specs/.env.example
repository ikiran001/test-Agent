# Copy to ".env" in this folder and fill in values. Never commit ".env".
#
# Required for this script
OPENAI_API_KEY=

# Only used if USE_LINKEDIN_DEMO=1 (see script comments; sending passwords to
# the LLM has provider/TOS/privacy risks — use for learning, not real accounts)
LINKEDIN_EMAIL=
LINKEDIN_PASSWORD=

# 0 = safe smoke test (example.com). 1 = use LINKEDIN_* from .env in the task
USE_LINKEDIN_DEMO=0
